---
import EntityArchive from "../../../components/EntityArchive.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import { entitySlug, projectsByTeacher, uniqueTeachers } from "../../../data/projects";
import "../../../styles/global.css";

export function getStaticPaths() {
  return uniqueTeachers().map((teacher) => ({
    params: { slug: entitySlug(teacher) },
    props: { teacher },
  }));
}

const { teacher } = Astro.props;
const teacherProjects = projectsByTeacher(teacher);
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={`Progetti supervisionati da ${teacher} nell’archivio ISIA Urbino Editorial Projects.`} />
    <title>{teacher} — ISIA Urbino Editorial Projects</title>
  </head>
  <body>
    <SiteHeader />
    <EntityArchive label="Docente" title={teacher} projects={teacherProjects} />
  </body>
</html>
