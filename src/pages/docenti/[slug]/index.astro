---
import EntityArchive from "../../../components/EntityArchive.astro";
import SeoHead from "../../../components/SeoHead.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import { entitySlug, projectsByTeacher, uniqueTeachers } from "../../../data/projects";
import "../../../styles/global.css";

export function getStaticPaths() {
  return uniqueTeachers().map((teacher) => ({
    params: { slug: entitySlug(teacher) },
    props: { teacher },
  }));
}

const { teacher } = Astro.props;
const teacherProjects = projectsByTeacher(teacher);
---

<!doctype html>
<html lang="it">
  <head>
    <SeoHead title={`${teacher} — ISIA Urbino Editorial Projects`} description={`Progetti supervisionati da ${teacher} nell’archivio ISIA Urbino Editorial Projects.`} pathname={`/docenti/${entitySlug(teacher)}/`} />
  </head>
  <body>
    <SiteHeader />
    <EntityArchive label="Docente" title={teacher} projects={teacherProjects} />
  </body>
</html>
