---
import EntityArchive from "../../../components/EntityArchive.astro";
import SeoHead from "../../../components/SeoHead.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import { courses, entitySlug, projectsByCourse, type Course } from "../../../data/projects";
import "../../../styles/global.css";

export function getStaticPaths() {
  return courses.map((course) => ({
    params: { slug: entitySlug(course) },
    props: { course },
  }));
}

const { course } = Astro.props as { course: Course };
const courseProjects = projectsByCourse(course);
---

<!doctype html>
<html lang="it">
  <head>
    <SeoHead title={`${course} — ISIA Urbino Editorial Projects`} description={`Progetti del corso ${course} nell’archivio ISIA Urbino Editorial Projects.`} pathname={`/corsi/${entitySlug(course)}/`} />
  </head>
  <body>
    <SiteHeader />
    <EntityArchive label="Corso" title={course} projects={courseProjects} />
  </body>
</html>
