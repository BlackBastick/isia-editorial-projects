---
import MetaLinks from "../../components/MetaLinks.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { courseLabels, entitySlug, getProjectGallery, isVideo, projects, type Project } from "../../data/projects";
import "../../styles/global.css";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const gallery = getProjectGallery(project);
---

<!doctype html>
<html lang="it" class="project-detail-page">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={project.description} />
    <title>{project.title} — ISIA Urbino Editorial Projects</title>
  </head>
  <body>
    <SiteHeader />

    <main class="project-page">
      <aside class="project-info">
        <nav class="breadcrumb" aria-label="Percorso">
          <a href="/">Projects</a>
          <span aria-hidden="true">›</span>
          <a href={`/corsi/${entitySlug(project.course)}/`}>{courseLabels[project.course]}</a>
        </nav>
        <dl>
          <div>
            <dt>Progetto</dt>
            <dd>{project.title}</dd>
          </div>
          <div>
            <dt>{project.student.includes(",") ? "Studenti" : "Studente"}</dt>
            <dd><MetaLinks kind="student" value={project.student} /></dd>
          </div>
          {
            project.subject && (
              <div>
                <dt>Corso</dt>
                <dd><MetaLinks kind="subject" value={project.subject} /></dd>
              </div>
            )
          }
          <div>
            <dt>Docente</dt>
            <dd><MetaLinks kind="teacher" value={project.teacher} /></dd>
          </div>
          <div>
            <dt>Anno</dt>
            <dd><MetaLinks kind="year" value={project.year} /></dd>
          </div>
          <div>
            <dt>Indirizzo</dt>
            <dd><MetaLinks kind="course" value={project.course} /></dd>
          </div>
        </dl>
        <p>{project.description}</p>
      </aside>

      <div class="project-gallery">
        {
          gallery.map((media, index) => (
            isVideo(media) ? (
              <video
                src={media}
                aria-label={index === 0 ? project.imageAlt : `Video ${index + 1} del progetto ${project.title}`}
                data-gallery-media
                autoplay
                muted
                loop
                playsinline
                preload={index === 0 ? "auto" : "metadata"}
              />
            ) : (
              <img
                src={media}
                alt={index === 0 ? project.imageAlt : `Immagine ${index + 1} del progetto ${project.title}`}
                data-gallery-media
                loading={index === 0 ? "eager" : "lazy"}
                width="1200"
                height="1500"
              />
            )
          ))
        }
      </div>
    </main>
    <script>
      const projectInfo = document.querySelector<HTMLElement>(".project-info");
      const projectGallery = document.querySelector<HTMLElement>(".project-gallery");
      const siteTitle = document.querySelector<HTMLElement>(".site-title");
      const syncProjectInfoHeight = () => {
        if (!projectInfo) return;
        projectInfo.style.setProperty("--project-info-height", `${projectInfo.scrollHeight}px`);
        if (projectGallery) {
          const galleryTop = projectGallery.getBoundingClientRect().top + scrollY;
          projectInfo.style.setProperty("--project-stick-start", `${Math.max(0, galleryTop)}px`);
        }
      };

      requestAnimationFrame(syncProjectInfoHeight);
      document.fonts?.ready.then(syncProjectInfoHeight);
      addEventListener("resize", syncProjectInfoHeight);
      if (projectInfo) new ResizeObserver(syncProjectInfoHeight).observe(projectInfo);
      if (siteTitle) new MutationObserver(syncProjectInfoHeight).observe(siteTitle, { attributes: true, attributeFilter: ["class"] });

      document.querySelectorAll("img[data-gallery-media]").forEach((image) => {
        const img = image as HTMLImageElement;
        const mark = () => {
          img.classList.toggle("is-landscape", img.naturalWidth > img.naturalHeight);
        };
        img.addEventListener("load", mark, { once: true });
        if (img.complete) mark();
      });

      document.querySelectorAll("video[data-gallery-media]").forEach((video) => {
        const vid = video as HTMLVideoElement;
        const mark = () => {
          vid.classList.toggle("is-landscape", vid.videoWidth > vid.videoHeight);
        };
        vid.addEventListener("loadedmetadata", mark, { once: true });
        if (vid.readyState >= 1) mark();
      });
    </script>
  </body>
</html>
