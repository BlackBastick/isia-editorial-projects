---
import ProjectCard from "../components/ProjectCard.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { projects } from "../data/projects";
import "../styles/global.css";
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Archivio indipendente dei progetti editoriali, fotografici e di illustrazione degli studenti ISIA Urbino."
    />
    <title>ISIA Urbino Editorial Projects</title>
  </head>
  <body>
    <SiteHeader />

    <main>
      <section class="project-grid" aria-label="Progetti">
        {projects.map((project, index) => <ProjectCard project={project} index={index} />)}
      </section>
    </main>

    <footer>
      <p>ISIA Urbino Editorial Projects</p>
      <p>Archivio indipendente a scopo didattico</p>
    </footer>

  </body>
</html>
