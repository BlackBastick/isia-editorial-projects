---
import ProjectCard from "../components/ProjectCard.astro";
import SeoHead from "../components/SeoHead.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { projectSearchTags, projects } from "../data/projects";
import "../styles/global.css";

const suggestedTags = [...new Set(projects.flatMap(projectSearchTags))];
---

<!doctype html>
<html lang="it">
  <head>
    <SeoHead />
  </head>
  <body>
    <SiteHeader hideMenuToggle />

    <main>
      <div class="home-nav">
        <nav class="home-tabs" aria-label="Filtra contenuti">
          <button class="home-tab is-active" type="button" data-home-filter="all" aria-pressed="true">Tutto</button>
          <button class="home-tab" type="button" data-home-filter="progetti" aria-pressed="false">Progetti</button>
          <button class="home-tab" type="button" data-home-filter="workshop" aria-pressed="false">Workshop</button>
          <button class="home-tab" type="button" data-home-filter="eventi" aria-pressed="false">Eventi</button>
        </nav>
        <section class="home-search" id="home-search" data-home-search hidden aria-label="Ricerca progetti">
          <div class="home-search__bar">
            <label class="sr-only" for="project-search">Cerca progetto o tag</label>
            <input id="project-search" type="text" inputmode="search" enterkeyhint="search" autocomplete="off" placeholder="Cerca titolo o tag" data-search-input />
            <button class="home-tab home-search__back" type="button" data-search-close>Indietro</button>
          </div>
          <div class="home-search__tags" aria-label="Tag consigliati">
            {suggestedTags.map((tag) => <button class="home-tab" type="button" data-search-tag={tag}>{tag}</button>)}
          </div>
          <h1 class="home-search__status" data-search-status hidden></h1>
        </section>
        <button class="search-toggle" type="button" aria-expanded="false" aria-controls="home-search" aria-label="Apri ricerca">
          <svg viewBox="0 0 60 60" aria-hidden="true" focusable="false">
            <path d="M43.02,37.74c2.92-3.95,4.51-8.78,4.51-13.75C47.53,11.21,37.13.81,24.35.81S1.18,11.21,1.18,23.99s10.4,23.17,23.17,23.17c4.59,0,8.98-1.32,12.77-3.84l16.71,16.46,5.62-5.49-16.43-16.55ZM24.35,6.84c9.46,0,17.15,7.69,17.15,17.15,0,5.39-2.46,10.37-6.75,13.64-3.01,2.3-6.6,3.51-10.4,3.51-9.46,0-17.15-7.7-17.15-17.15S14.9,6.84,24.35,6.84Z" />
          </svg>
        </button>
        <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu" aria-label="Apri menu">
          <img src="/hamburger-b.svg" alt="" aria-hidden="true" />
        </button>
      </div>

      <section class="project-grid" aria-label="Progetti">
        {projects.map((project, index) => <ProjectCard project={project} index={index} />)}
      </section>
    </main>

    <footer>
      <p>ISIA Urbino Editorial Projects</p>
      <p>Archivio indipendente a scopo didattico</p>
    </footer>

    <script>
      const homeTabs = [...document.querySelectorAll<HTMLButtonElement>("[data-home-filter]")];
      const projectCards = [...document.querySelectorAll<HTMLElement>("[data-project]")];
      const homeNav = document.querySelector<HTMLElement>(".home-nav");
      const searchPanel = document.querySelector<HTMLElement>("[data-home-search]");
      const searchToggle = document.querySelector<HTMLButtonElement>(".search-toggle");
      const searchClose = document.querySelector<HTMLButtonElement>("[data-search-close]");
      const searchInput = document.querySelector<HTMLInputElement>("[data-search-input]");
      const searchStatus = document.querySelector<HTMLElement>("[data-search-status]");
      const searchTags = [...document.querySelectorAll<HTMLButtonElement>("[data-search-tag]")];
      let activeFilter = "all";
      let activeQuery = "";
      let activeLabel = "";
      const mobileSearchQuery = matchMedia("(max-width: 42rem)");

      const normalize = (value: string) =>
        value
          .normalize("NFD")
          .replace(/[\u0300-\u036f]/g, "")
          .toLowerCase()
          .trim();

      const updateTags = () => {
        const query = normalize(searchInput?.value ?? "");
        const related = new Set<string>();
        projectCards.forEach((card) => {
          const haystack = normalize(card.dataset.search ?? "");
          const tags = (card.dataset.tags ?? "").split("|").filter(Boolean);
          if (!query || haystack.includes(query) || tags.some((tag) => normalize(tag).includes(query))) {
            tags.forEach((tag) => related.add(tag));
          }
        });
        let visible = 0;
        searchTags.forEach((tag) => {
          const value = tag.dataset.searchTag ?? "";
          const normalized = normalize(value);
          const show = query ? related.has(value.toLowerCase()) || normalized.includes(query) : visible < 12;
          tag.hidden = !show;
          tag.classList.toggle("is-active", Boolean(query) && normalized === query);
          if (show) visible += 1;
        });
      };

      const applyProjects = () => {
        const searching = homeNav?.classList.contains("has-search-open");
        const query = activeQuery;
        let visibleProjects = 0;
        projectCards.forEach((card) => {
          const matchesFilter = activeFilter === "all" || card.dataset.category === activeFilter;
          const matchesSearch = !query || normalize(card.dataset.search ?? "").includes(query);
          card.hidden = searching ? !matchesSearch : !matchesFilter;
          if (!card.hidden) visibleProjects += 1;
        });
        searchPanel?.classList.toggle("is-results", mobileSearchQuery.matches && Boolean(query));
        if (searchStatus) {
          searchStatus.hidden = !query;
          searchStatus.textContent = query
            ? visibleProjects
              ? `Filtro: ${activeLabel}, ${visibleProjects} ${visibleProjects === 1 ? "progetto" : "progetti"}`
              : "Nessun risultato trovato"
            : "";
        }
        updateTags();
      };

      const submitSearch = () => {
        activeLabel = (searchInput?.value ?? "").trim();
        activeQuery = normalize(searchInput?.value ?? "");
        applyProjects();
        searchInput?.blur();
      };

      const setSearch = (open: boolean) => {
        const changed = homeNav?.classList.contains("has-search-open") !== open;
        homeNav?.classList.toggle("has-search-open", open);
        document.documentElement.classList.toggle("has-search-open", open);
        searchPanel?.toggleAttribute("hidden", !open);
        searchToggle?.setAttribute("aria-expanded", String(open));
        if (open) {
          requestAnimationFrame(() => searchInput?.focus());
        } else {
          if (searchInput) searchInput.value = "";
          activeQuery = "";
          activeLabel = "";
        }
        applyProjects();
        if (changed) dispatchEvent(new Event("site-title-relayout"));
      };

      homeTabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          activeFilter = tab.dataset.homeFilter ?? "all";
          homeTabs.forEach((item) => {
            const active = item === tab;
            item.classList.toggle("is-active", active);
            item.setAttribute("aria-pressed", String(active));
          });
          applyProjects();
        });
      });

      searchToggle?.addEventListener("click", () => setSearch(true));
      searchClose?.addEventListener("click", () => setSearch(false));
      searchInput?.addEventListener("input", updateTags);
      searchInput?.addEventListener("keydown", (event) => {
        if (event.key === "Enter") {
          event.preventDefault();
          submitSearch();
        }
      });
      searchTags.forEach((tag) => {
        tag.addEventListener("click", () => {
          if (searchInput) searchInput.value = tag.dataset.searchTag ?? "";
          submitSearch();
        });
      });
      addEventListener("keydown", (event) => {
        if (event.key === "Escape") setSearch(false);
      });
    </script>
  </body>
</html>
