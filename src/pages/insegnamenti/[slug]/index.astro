---
import EntityArchive from "../../../components/EntityArchive.astro";
import SeoHead from "../../../components/SeoHead.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import { entitySlug, projectsBySubject, uniqueSubjects } from "../../../data/projects";
import "../../../styles/global.css";

export function getStaticPaths() {
  return uniqueSubjects().map((subject) => ({
    params: { slug: entitySlug(subject) },
    props: { subject },
  }));
}

const { subject } = Astro.props;
const subjectProjects = projectsBySubject(subject);
---

<!doctype html>
<html lang="it">
  <head>
    <SeoHead title={`${subject} — ISIA Urbino Editorial Projects`} description={`Progetti del corso ${subject} nell’archivio ISIA Urbino Editorial Projects.`} pathname={`/insegnamenti/${entitySlug(subject)}/`} />
  </head>
  <body>
    <SiteHeader />
    <EntityArchive label="Corso" title={subject} projects={subjectProjects} />
  </body>
</html>
