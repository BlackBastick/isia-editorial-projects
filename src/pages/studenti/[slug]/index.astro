---
import EntityArchive from "../../../components/EntityArchive.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import { entitySlug, projectsByStudent, uniqueStudents } from "../../../data/projects";
import "../../../styles/global.css";

export function getStaticPaths() {
  return uniqueStudents().map((student) => ({
    params: { slug: entitySlug(student) },
    props: { student },
  }));
}

const { student } = Astro.props;
const studentProjects = projectsByStudent(student);
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={`Progetti di ${student} nell’archivio ISIA Urbino Editorial Projects.`} />
    <title>{student} — ISIA Urbino Editorial Projects</title>
  </head>
  <body>
    <SiteHeader />
    <EntityArchive label="Studente" title={student} projects={studentProjects} />
  </body>
</html>
