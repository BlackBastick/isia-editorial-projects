---
import EntityArchive from "../../../components/EntityArchive.astro";
import SeoHead from "../../../components/SeoHead.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import { entitySlug, projectsByStudent, uniqueStudents } from "../../../data/projects";
import "../../../styles/global.css";

export function getStaticPaths() {
  return uniqueStudents().map((student) => ({
    params: { slug: entitySlug(student) },
    props: { student },
  }));
}

const { student } = Astro.props;
const studentProjects = projectsByStudent(student);
---

<!doctype html>
<html lang="it">
  <head>
    <SeoHead title={`${student} — ISIA Urbino Editorial Projects`} description={`Progetti di ${student} nell’archivio ISIA Urbino Editorial Projects.`} pathname={`/studenti/${entitySlug(student)}/`} />
  </head>
  <body>
    <SiteHeader />
    <EntityArchive label="Studente" title={student} projects={studentProjects} />
  </body>
</html>
