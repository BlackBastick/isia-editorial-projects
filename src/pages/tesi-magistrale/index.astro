---
import EntityArchive from "../../components/EntityArchive.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { projects } from "../../data/projects";
import "../../styles/global.css";

const tesiProjects = projects.filter((project) => project.subject?.toLowerCase().includes("tesi magistrale"));
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Tesi magistrali nell’archivio ISIA Urbino Editorial Projects." />
    <title>Tesi magistrale — ISIA Urbino Editorial Projects</title>
  </head>
  <body>
    <SiteHeader />
    <EntityArchive label="Sezione" title="Tesi magistrale" projects={tesiProjects} />
  </body>
</html>
