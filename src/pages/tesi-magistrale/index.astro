---
import EntityArchive from "../../components/EntityArchive.astro";
import SeoHead from "../../components/SeoHead.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { projects } from "../../data/projects";
import "../../styles/global.css";

const tesiProjects = projects.filter((project) => project.subject?.toLowerCase().includes("tesi magistrale"));
---

<!doctype html>
<html lang="it">
  <head>
    <SeoHead title="Tesi magistrale — ISIA Urbino Editorial Projects" description="Tesi magistrali nell’archivio ISIA Urbino Editorial Projects." pathname="/tesi-magistrale/" />
  </head>
  <body>
    <SiteHeader />
    <EntityArchive label="Sezione" title="Tesi magistrale" projects={tesiProjects} />
  </body>
</html>
