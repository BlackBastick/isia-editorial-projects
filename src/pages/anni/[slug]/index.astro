---
import EntityArchive from "../../../components/EntityArchive.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import { projectsByYear, uniqueYears } from "../../../data/projects";
import "../../../styles/global.css";

export function getStaticPaths() {
  return uniqueYears().map((year) => ({
    params: { slug: String(year) },
    props: { year },
  }));
}

const { year } = Astro.props;
const yearProjects = projectsByYear(year);
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={`Progetti dell’anno ${year} nell’archivio ISIA Urbino Editorial Projects.`} />
    <title>{year} — ISIA Urbino Editorial Projects</title>
  </head>
  <body>
    <SiteHeader />
    <EntityArchive label="Anno" title={String(year)} projects={yearProjects} />
  </body>
</html>
