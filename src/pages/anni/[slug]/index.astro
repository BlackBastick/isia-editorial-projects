---
import EntityArchive from "../../../components/EntityArchive.astro";
import SeoHead from "../../../components/SeoHead.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import { projectsByYear, uniqueYears } from "../../../data/projects";
import "../../../styles/global.css";

export function getStaticPaths() {
  return uniqueYears().map((year) => ({
    params: { slug: String(year) },
    props: { year },
  }));
}

const { year } = Astro.props;
const yearProjects = projectsByYear(year);
---

<!doctype html>
<html lang="it">
  <head>
    <SeoHead title={`${year} — ISIA Urbino Editorial Projects`} description={`Progetti dell’anno ${year} nell’archivio ISIA Urbino Editorial Projects.`} pathname={`/anni/${year}/`} />
  </head>
  <body>
    <SiteHeader />
    <EntityArchive label="Anno" title={String(year)} projects={yearProjects} />
  </body>
</html>
