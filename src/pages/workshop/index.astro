---
import EntityArchive from "../../components/EntityArchive.astro";
import SeoHead from "../../components/SeoHead.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { projects } from "../../data/projects";
import "../../styles/global.css";

const workshopProjects = projects.filter((project) => project.subject?.toLowerCase().includes("workshop"));
---

<!doctype html>
<html lang="it">
  <head>
    <SeoHead title="Workshop — ISIA Urbino Editorial Projects" description="Workshop nell’archivio ISIA Urbino Editorial Projects." pathname="/workshop/" />
  </head>
  <body>
    <SiteHeader />
    <EntityArchive label="Sezione" title="Workshop" projects={workshopProjects} />
  </body>
</html>
