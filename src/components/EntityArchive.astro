---
import ProjectCard from "./ProjectCard.astro";
import type { Project } from "../data/projects";

interface Props {
  label: string;
  title: string;
  projects: Project[];
}

const { label, title, projects } = Astro.props;
---

<main class="entity-page">
  <header class="entity-heading">
    <p>{label}</p>
    <h1>{title}</h1>
    <p>{projects.length} {projects.length === 1 ? "progetto" : "progetti"}</p>
  </header>

  <section class="project-grid" aria-label={`Progetti: ${title}`}>
    {projects.map((project, index) => <ProjectCard project={project} index={index} />)}
  </section>
</main>
