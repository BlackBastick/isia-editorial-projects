---
import { courses, entitySlug } from "../data/projects";

const { hideMenuToggle = false } = Astro.props;

const menuCourseLabels = {
  [courses[0]]: "Triennio",
  [courses[1]]: "Biennio Editoria",
  [courses[2]]: "Biennio Fotografia",
  [courses[3]]: "Biennio Illustrazione",
};
---

<header class="site-header">
  <span class="site-title" aria-hidden="true">
    {
      [..."ISIA URBINO EDITORIAL PROJECT"].map((character) =>
        character === " "
          ? <span class="site-title__space"> </span>
          : <span class="site-title__letter">{character}</span>
      )
    }
  </span>
  {
    !hideMenuToggle && (
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu" aria-label="Apri menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    )
  }
  <a class="site-frame-link" href="/" aria-label="Torna alla homepage">
    <span class="site-frame-link__top"></span>
    <span class="site-frame-link__right"></span>
    <span class="site-frame-link__bottom"></span>
    <span class="site-frame-link__left"></span>
  </a>
</header>

<aside class="site-menu" id="site-menu" aria-hidden="true">
  <button class="menu-close" type="button" aria-label="Chiudi menu">×</button>
  <nav aria-label="Filtri archivio">
    <a href="/">Tutti i progetti</a>
    <span aria-hidden="true">—</span>
    {
      courses.map((course) => <a href={`/corsi/${entitySlug(course)}/`}>{menuCourseLabels[course]}</a>)
    }
    <span aria-hidden="true">—</span>
    <a href="/tesi-triennale/">Tesi triennale</a>
    <a href="/tesi-magistrale/">Tesi magistrale</a>
    <span aria-hidden="true">—</span>
    <a href="/workshop/">Workshop</a>
  </nav>
</aside>

<div class="site-intro" aria-hidden="true">
  <div>
    <p class="site-intro__logo">ISIA URBINO EDITORIAL PROJECT</p>
    <p class="site-intro__school">
      <span class="site-intro__school-line">Istituto</span>
      <span class="site-intro__school-line site-intro__school-line--flush">Superiore per le</span>
      <span class="site-intro__school-line">Industrie</span>
      <span class="site-intro__school-line site-intro__school-line--flush">Artistiche di</span>
      <span class="site-intro__school-line site-intro__school-line--flush">Urbino</span>
    </p>
  </div>
</div>

<script>
  const mark = document.querySelector<HTMLElement>(".site-title");
  const intro = document.querySelector<HTMLElement>(".site-intro");
  const letters = [...document.querySelectorAll<HTMLElement>(".site-title__letter")];
  const menu = document.querySelector<HTMLElement>(".site-menu");
  const menuToggle = document.querySelector<HTMLButtonElement>(".menu-toggle");
  const menuClose = document.querySelector<HTMLButtonElement>(".menu-close");
  const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
  let relayoutLetters = (_animate = false) => {};
  const requestTitleRelayout = () => requestAnimationFrame(() => relayoutLetters(true));
  const syncHomeNavOffset = () => {
    const navAnchor = document.querySelector<HTMLElement>(".home-nav, .entity-heading, .project-info");
    if (!navAnchor) return;
    document.documentElement.style.setProperty("--home-nav-y", `${navAnchor.getBoundingClientRect().top}px`);
  };

  if ("scrollRestoration" in history) history.scrollRestoration = "manual";
  scrollTo(0, 0);
  requestAnimationFrame(() => {
    scrollTo(0, 0);
    document.querySelector("main")?.scrollTo(0, 0);
    syncHomeNavOffset();
  });

  const setMenu = (open: boolean) => {
    const changed = document.documentElement.classList.contains("has-menu-open") !== open;
    document.documentElement.classList.toggle("has-menu-open", open);
    menu?.setAttribute("aria-hidden", String(!open));
    menuToggle?.setAttribute("aria-expanded", String(open));
    menuToggle?.setAttribute("aria-label", open ? "Chiudi menu" : "Apri menu");
    if (changed) requestTitleRelayout();
  };

  menuToggle?.addEventListener("click", () => setMenu(!document.documentElement.classList.contains("has-menu-open")));
  menuClose?.addEventListener("click", () => setMenu(false));
  addEventListener("site-title-relayout", requestTitleRelayout);
  addEventListener("keydown", (event) => {
    if (event.key === "Escape") setMenu(false);
  });

  if (mark && letters.length) {
    await document.fonts.ready;
    const introLogo = document.querySelector<HTMLElement>(".site-intro__logo");
    const introOrigin = introLogo?.getBoundingClientRect();
    const gutterValue = getComputedStyle(document.documentElement).getPropertyValue("--page-gutter").trim();
    const rootSize = Number.parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
    const gutter = gutterValue.endsWith("rem")
      ? Number.parseFloat(gutterValue) * rootSize
      : Number.parseFloat(gutterValue) || 20;
    const edgeInset = gutter / 2;
    const mobileQuery = matchMedia("(max-width: 42rem)");
    const freezeMobileFrame = mobileQuery.matches;
    const frozenFrame = {
      width: visualViewport?.width ?? innerWidth,
      height: visualViewport?.height ?? innerHeight,
    };
    type EdgeSide = "top" | "right" | "bottom" | "left";
    type EdgePoint = { x: number; y: number; side: EdgeSide };
    const makeSlots = (spread = 0.96, previousSlots: number[] = []) => {
      const build = () => {
        const weights = letters.slice(1).map(() =>
          Math.random() < 0.35 ? 0.35 + Math.random() * 0.35 : 0.9 + Math.random() * 1.5
        );
        const total = weights.reduce((sum, weight) => sum + weight, 0);
        let cursor = 0;
        return [0, ...weights.map((weight) => (cursor += (weight / total) * spread))];
      };

      let next = build();
      for (let tries = 0; previousSlots.length && tries < 4; tries += 1) {
        const changed = next.filter((slot, index) => index > 0 && Math.abs(slot - previousSlots[index]) > 0.025).length;
        if (changed > letters.length * 0.55) break;
        next = build();
      }
      return next;
    };
    const makeNearbySlots = (previousSlots: number[], spread = 0.96) => {
      if (!previousSlots.length) return makeSlots(spread);
      const step = spread / (letters.length - 1);
      const minGap = step * 0.45;
      const next = previousSlots.map((slot, index) => {
        if (index === 0) return 0;
        const anchor = index * step;
        const targetSlot = Math.min(spread, Math.max(0, anchor + (Math.random() - 0.5) * step * 1.2));
        return slot * 0.35 + targetSlot * 0.65;
      });
      for (let index = next.length - 1; index > 0; index -= 1) {
        next[index] = Math.min(next[index], spread - (next.length - 1 - index) * minGap);
      }
      for (let index = 1; index < next.length; index += 1) {
        next[index] = Math.max(next[index], next[index - 1] + minGap);
      }
      return next;
    };
    let slots = makeSlots();

    const placeLetters = (animate = false) => {
      const sources = letters.map((letter) => {
        const rect = letter.getBoundingClientRect();
        return {
          left: rect.left,
          top: rect.top,
          width: letter.offsetWidth || rect.width,
          height: letter.offsetHeight || rect.height,
        };
      });
      letters.forEach((letter) => letter.getAnimations().forEach((animation) => animation.cancel()));
      mark.style.position = "fixed";
      mark.style.left = `${edgeInset}px`;
      mark.style.top = `${edgeInset}px`;
      const frameWidth = freezeMobileFrame ? frozenFrame.width : innerWidth;
      const frameHeight = freezeMobileFrame ? frozenFrame.height : innerHeight;
      const isMobile = mobileQuery.matches;
      if (animate) slots = isMobile ? makeNearbySlots(slots) : makeSlots(0.96, slots);
      const origin = {
        x: (introOrigin?.left ?? gutter) + sources[0].width / 2,
        y: (introOrigin?.top ?? 2) + sources[0].height / 2,
      };
      const right = frameWidth - edgeInset;
      const bottom = frameHeight - edgeInset;
      const topWidth = right - origin.x;
      const sideHeight = bottom - origin.y;
      const bottomWidth = right - origin.x;
      const perimeter = isMobile ? topWidth + sideHeight * 2 : topWidth + sideHeight * 2 + bottomWidth;

      const pointAt = (distance: number): EdgePoint => {
        if (distance <= topWidth) return { x: origin.x + distance, y: origin.y, side: "top" };
        distance -= topWidth;
        if (distance <= sideHeight) return { x: right, y: origin.y + distance, side: "right" };
        distance -= sideHeight;
        if (isMobile) return { x: edgeInset, y: bottom - distance, side: "left" };
        if (distance <= bottomWidth) return { x: right - distance, y: bottom, side: "bottom" };
        distance -= bottomWidth;
        return { x: edgeInset, y: bottom - distance, side: "left" };
      };

      const points = slots.map((slot) => pointAt(slot * perimeter));
      const place = (point: EdgePoint, rect: { width: number; height: number }) => ({
        x: point.x - rect.width / 2,
        y: point.y - rect.height / 2,
        side: point.side,
      });
      const nearestSide = (point: { x: number; y: number }) =>
        [
          { side: "top", distance: Math.abs(point.y - origin.y) },
          { side: "right", distance: Math.abs(point.x - right) },
          ...(isMobile ? [] : [{ side: "bottom", distance: Math.abs(point.y - bottom) }]),
          { side: "left", distance: Math.abs(point.x - edgeInset) },
        ].sort((a, b) => a.distance - b.distance)[0].side as EdgeSide;
      const samePoint = (a: { x: number; y: number }, b: { x: number; y: number }) =>
        Math.abs(a.x - b.x) < 0.5 && Math.abs(a.y - b.y) < 0.5;
      const addWaypoint = (
        path: { x: number; y: number }[],
        point: EdgePoint,
        rect: { width: number; height: number }
      ) => {
        const next = place(point, rect);
        if (!samePoint(path[path.length - 1], next)) path.push(next);
      };

      mark.classList.add("is-scattered");

      letters.forEach((letter, index) => {
        const source = sources[index];
        const target = place(points[index], source);
        letter.style.left = `${target.x}px`;
        letter.style.top = `${target.y}px`;
        letter.style.opacity = "1";

        if (!animate || index === 0) return;

        const sourcePoint = {
          x: source.left + source.width / 2,
          y: source.top + source.height / 2,
        };
        const sourceSide = nearestSide(sourcePoint);
        const path = [{ x: source.left, y: source.top }];

        if (sourceSide !== target.side) {
          if (isMobile) {
            if (sourceSide === "right" && target.side === "left") {
              addWaypoint(path, { x: right, y: bottom, side: "right" }, source);
              addWaypoint(path, { x: edgeInset, y: bottom, side: "left" }, source);
            } else if (sourceSide === "left" && target.side === "right") {
              addWaypoint(path, { x: edgeInset, y: bottom, side: "left" }, source);
              addWaypoint(path, { x: right, y: bottom, side: "right" }, source);
            } else {
              if (sourceSide === "left") addWaypoint(path, { x: edgeInset, y: origin.y, side: "left" }, source);
              if (sourceSide === "right") addWaypoint(path, { x: right, y: origin.y, side: "right" }, source);
              if (target.side === "right") addWaypoint(path, { x: right, y: origin.y, side: "right" }, source);
              if (target.side === "left") addWaypoint(path, { x: edgeInset, y: origin.y, side: "left" }, source);
            }
          } else {
            const clockwise: Record<EdgeSide, { point: EdgePoint; side: EdgeSide }> = {
              top: { point: { x: right, y: origin.y, side: "right" }, side: "right" },
              right: { point: { x: right, y: bottom, side: "bottom" }, side: "bottom" },
              bottom: { point: { x: edgeInset, y: bottom, side: "left" }, side: "left" },
              left: { point: { x: edgeInset, y: origin.y, side: "top" }, side: "top" },
            };
            const counterClockwise: Record<EdgeSide, { point: EdgePoint; side: EdgeSide }> = {
              top: { point: { x: edgeInset, y: origin.y, side: "left" }, side: "left" },
              left: { point: { x: edgeInset, y: bottom, side: "bottom" }, side: "bottom" },
              bottom: { point: { x: right, y: bottom, side: "right" }, side: "right" },
              right: { point: { x: right, y: origin.y, side: "top" }, side: "top" },
            };
            const route = (edges: typeof clockwise) => {
              const nextPath = [{ x: source.left, y: source.top }];
              let currentSide = sourceSide;
              for (let step = 0; currentSide !== target.side && step < 4; step += 1) {
                const next = edges[currentSide];
                addWaypoint(nextPath, next.point, source);
                currentSide = next.side;
              }
              nextPath.push(target);
              return nextPath;
            };
            const distance = (nextPath: { x: number; y: number }[]) =>
              nextPath.slice(1).reduce((sum, point, pointIndex) =>
                sum + Math.hypot(point.x - nextPath[pointIndex].x, point.y - nextPath[pointIndex].y), 0);
            path.splice(0, path.length, ...[route(clockwise), route(counterClockwise)].sort((a, b) => distance(a) - distance(b))[0]);
          }
        }

        if (!samePoint(path[path.length - 1], target)) path.push(target);

        const distances = path.slice(1).map((point, pointIndex) =>
          Math.hypot(point.x - path[pointIndex].x, point.y - path[pointIndex].y)
        );
        const total = distances.reduce((sum, distance) => sum + distance, 0);
        let travelled = 0;
        const keyframes = path.map((point, pointIndex) => {
          if (pointIndex > 0) travelled += distances[pointIndex - 1];
          return {
            offset: total ? travelled / total : 1,
            transform: `translate(${point.x - target.x}px, ${point.y - target.y}px)`,
          };
        });

        letter.animate(keyframes, {
          duration: 1800,
          easing: "cubic-bezier(0.16, 1, 0.3, 1)",
          fill: "both",
        });
      });
    };
    relayoutLetters = placeLetters;
    let resizeFrame = 0;
    const resize = () => {
      cancelAnimationFrame(resizeFrame);
      resizeFrame = requestAnimationFrame(() => placeLetters());
    };

    if (reduceMotion) {
      intro?.remove();
    } else {
      setTimeout(() => {
        intro?.classList.add("is-leaving");
        placeLetters(true);
        syncHomeNavOffset();
        setTimeout(() => intro?.remove(), 900);
      }, 1100);
      if (!freezeMobileFrame) {
        addEventListener("resize", resize);
        addEventListener("resize", syncHomeNavOffset);
      }
    }
  } else {
    intro?.remove();
  }
</script>
