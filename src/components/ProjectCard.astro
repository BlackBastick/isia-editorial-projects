---
import MetaLinks from "./MetaLinks.astro";
import { isVideo, type Project } from "../data/projects";

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
const description = project.description.replace(/\s+/g, " ").trim();
const coverIsVideo = isVideo(project.image);
const categoryText = [project.subject, project.title, project.description].join(" ").toLowerCase();
const category = categoryText.includes("workshop") ? "workshop" : categoryText.includes("cake") || categoryText.includes("evento") ? "eventi" : "progetti";
const isWorkshop = category === "workshop";
const participantLabel = isWorkshop ? "Partecipanti" : project.student.includes(",") ? "Studenti" : "Studente";
const teacherLabel = isWorkshop ? "A cura di" : "Docente";
const searchText = [project.title, ...(project.tags ?? [])].join(" ").toLowerCase();
const searchTags = (project.tags ?? []).join("|").toLowerCase();
---

<article class="project-card" data-project data-course={project.course} data-category={category} data-search={searchText} data-tags={searchTags}>
  <a class="project-card__link" href={`/projects/${project.slug}/`} aria-label={`Apri il progetto ${project.title}`}>
    <div class="project-card__image">
      {
        coverIsVideo ? (
          <video src={project.image} aria-label={project.imageAlt} autoplay muted loop playsinline preload={index < 3 ? "auto" : "metadata"} />
        ) : (
          <img
            src={project.image}
            alt={project.imageAlt}
            loading={index < 3 ? "eager" : "lazy"}
            fetchpriority={index === 0 ? "high" : "auto"}
            width="1200"
            height="1500"
          />
        )
      }
    </div>
  </a>
  <div class="project-card__content">
    <dl class="project-card__meta">
      <div>
        <dt>Progetto</dt>
        <dd><a class="project-title-link" href={`/projects/${project.slug}/`}>{project.title}</a></dd>
      </div>
      <div>
        <dt>{participantLabel}</dt>
        <dd>{isWorkshop ? <MetaLinks kind="course" value={project.course} /> : <MetaLinks kind="student" value={project.student} />}</dd>
      </div>
      {
        project.guest && (
          <div>
            <dt>Ospite</dt>
            <dd>{project.guest}</dd>
          </div>
        )
      }
      <div>
        <dt>{teacherLabel}</dt>
        <dd><MetaLinks kind="teacher" value={project.teacher} /></dd>
      </div>
      <div>
        <dt>Anno</dt>
        <dd><MetaLinks kind="year" value={project.year} /></dd>
      </div>
      <div class="project-card__course">
        <dt>Indirizzo</dt>
        <dd><MetaLinks kind="course" value={project.course} /></dd>
      </div>
      {
        project.subject && (
          <div>
            <dt>Corso</dt>
            <dd><MetaLinks kind="subject" value={project.subject} /></dd>
          </div>
        )
      }
    </dl>

    <p class="project-card__description">{description}</p>
  </div>
</article>
